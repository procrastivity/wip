#!/usr/bin/env bash
# wip-plumbing — deterministic core for wip. Main dispatcher.
#
# Parses global flags, sources the lib, dispatches to a subcommand file in
# $WIP_LIB/wip-plumbing-subcommands/<name>.bash (each defines a single
# function `wip_plumbing_cmd_<name>`). Never calls an LLM. See
# engineering/specs/wip-plumbing-cli.md for the contract.
set -euo pipefail

# shellcheck disable=SC1007  # CDPATH= prefixes the cd command (neutralize CDPATH), not an assignment
WIP_LIB="${WIP_LIB:-$(CDPATH= cd -- "$(dirname -- "$0")/../lib/wip" && pwd)}"
export WIP_LIB

# shellcheck source=lib/wip/wip-plumbing-lib.bash
source "$WIP_LIB/wip-plumbing-lib.bash"
# shellcheck source=lib/wip/wip-plumbing-registry-lib.bash
source "$WIP_LIB/wip-plumbing-registry-lib.bash"
# shellcheck source=lib/wip/wip-plumbing-scaffold-lib.bash
source "$WIP_LIB/wip-plumbing-scaffold-lib.bash"
# shellcheck source=lib/wip/wip-plumbing-intake-lib.bash
source "$WIP_LIB/wip-plumbing-intake-lib.bash"
# shellcheck source=lib/wip/wip-plumbing-roadmap-lib.bash
source "$WIP_LIB/wip-plumbing-roadmap-lib.bash"
# shellcheck source=lib/wip/wip-plumbing-amend-lib.bash
source "$WIP_LIB/wip-plumbing-amend-lib.bash"
# shellcheck source=lib/wip/wip-plumbing-ship-roadmap-lib.bash
source "$WIP_LIB/wip-plumbing-ship-roadmap-lib.bash"
# shellcheck source=lib/wip/wip-plumbing-ship-manifest-lib.bash
source "$WIP_LIB/wip-plumbing-ship-manifest-lib.bash"
# shellcheck source=lib/wip/wip-plumbing-forge-lib.bash
source "$WIP_LIB/wip-plumbing-forge-lib.bash"

WIP_JSON=1
WIP_VERBOSE=0
WIP_QUIET=0
WIP_DRY_RUN=0
_wip_project_id=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h | --help | help)
      wip_usage
      exit 0
      ;;
    --version)
      printf 'wip-plumbing %s\n' "$(wip_version)"
      exit 0
      ;;
    -v | --verbose) WIP_VERBOSE=1 ;;
    -q | --quiet) WIP_QUIET=1 ;;
    --json) WIP_JSON=1 ;;
    --no-json) WIP_JSON=0 ;;
    --dry-run) WIP_DRY_RUN=1 ;;
    --project)
      [[ $# -ge 2 ]] || wip_die 2 usage "--project requires an argument"
      _wip_project_id="$2"
      shift
      ;;
    --project=*) _wip_project_id="${1#--project=}" ;;
    --)
      shift
      break
      ;;
    -*) wip_die 2 usage "unknown global flag: $1" ;;
    *) break ;;
  esac
  shift
done
export WIP_JSON WIP_VERBOSE WIP_QUIET WIP_DRY_RUN

cmd="${1:-}"
[[ -n "$cmd" ]] || {
  wip_usage
  exit 2
}
shift || true

# --project <id> arg-prelude: also accept the flag positioned after the verb,
# strip it from argv before dispatch. Resolve once and export WIP_ROOT.
_wip_filtered_args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)
      [[ $# -ge 2 ]] || wip_die 2 usage "--project requires an argument"
      _wip_project_id="$2"
      shift 2
      ;;
    --project=*)
      _wip_project_id="${1#--project=}"
      shift
      ;;
    *)
      _wip_filtered_args+=("$1")
      shift
      ;;
  esac
done
if [[ -n "$_wip_project_id" ]]; then
  set +e
  _wip_resolved="$(wip_registry_resolve "$_wip_project_id" 2>/dev/null)"
  _wip_resolved_rc=$?
  set -e
  case "$_wip_resolved_rc" in
    0)
      WIP_ROOT="$_wip_resolved"
      export WIP_ROOT
      ;;
    3) wip_die 3 not-found "--project $_wip_project_id matched nothing" ;;
    4) wip_die 4 ambiguous "--project $_wip_project_id is ambiguous" ;;
    *) wip_die 1 internal "--project $_wip_project_id: resolve failed" ;;
  esac
fi
set -- "${_wip_filtered_args[@]+"${_wip_filtered_args[@]}"}"

case "$cmd" in
  detect | doctor | project | init | intake | status | next | roadmap | workplan | orchestrate | template | glossary | setup | graduate | extract | ship | forge)
    # shellcheck disable=SC1090
    source "$WIP_LIB/wip-plumbing-subcommands/$cmd.bash"
    "wip_plumbing_cmd_$cmd" "$@"
    ;;
  *) wip_die 2 usage "unknown command: $cmd" ;;
esac
